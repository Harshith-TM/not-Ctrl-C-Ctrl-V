<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/night"
    tools:context=".constraintLayoutFlow">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/ConstraintLayoutFlow"
        android:textColor="@color/imperial"
        android:textSize="30sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/constraint_layout_flow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textView1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/textView1"
        android:textColor="@color/imperial"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/textView2"
        android:textColor="@color/imperial"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/textView3"
        android:textColor="@color/imperial"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/textView4"
        android:textColor="@color/imperial"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/textView5"
        android:textColor="@color/imperial"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/anton"
        android:text="@string/textView6"
        android:textColor="@color/imperial"
        android:textSize="25sp" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/constraint_layout_flow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp"

        app:constraint_referenced_ids="textView1,textView2,textView3,textView4,textView5,textView6"

        app:flow_horizontalAlign="center"
        app:flow_horizontalBias="0.5"
        app:flow_horizontalGap="20dp"
        app:flow_horizontalStyle="spread_inside"

        app:flow_verticalAlign="center"
        app:flow_verticalBias="0.5"
        app:flow_verticalGap="20dp"
        app:flow_verticalStyle="spread_inside"

        app:flow_wrapMode="chain"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<!--Colors:
    night: #000F08
    imperial: #FB3640-->

<!--String:
    <string name="ConstraintLayoutFlow">Constraint Layout Flow</string>
    <string name="textView1">TEXTVIEW-1</string>
    <string name="textView2">TEXTVIEW-2</string>
    <string name="textView3">TEXTVIEW-3</string>
    <string name="textView4">TEXTVIEW-4</string>
    <string name="textView5">TEXTVIEW-5</string>
    <string name="textView6">TEXTVIEW-6</string>-->

<!--
Constraint layout flow helper: ConstraintLayout to automatically arrange
multiple views (like chips, button or text views) in rows and columns.
Uses:
- avoids nested layouts
- behaves like CSS Flexbox [CSS Flexbox: a 1-d layout model used to align items in
  rows or columns while efficiently distributing space within a container]
- supports wrapping automatically
- useful in responsive UI
- improves performance -->