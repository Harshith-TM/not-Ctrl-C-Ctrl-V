<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/night"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="50dp"
    tools:context=".SimpleAlertDialog">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat"
        android:text="@string/AlertDialog"
        android:textColor="@color/imperial"
        android:textSize="30sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/ShowAlertButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/imperial"
        android:fontFamily="@font/montserrat"
        android:text="@string/Show_Alert_Dialog"
        android:textColor="@color/night"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>

    <!--An Alert Dialog in Android is a small popup window that appears on top of the current
    screen to notify the user about important information, request confirmation, or ask the
    user to make a decision before continuing.

    Characteristics of an Alert Dialog
    >Displays a title, message, and one or more buttons.
    >Temporarily blocks interaction with the underlying activity until the dialog is dismissed.

    Commonly used for:
    >Confirming actions (e.g., "Delete this item?")
    >Showing warnings or errors
    >Requesting simple user input
    >Presenting a list of choices-->